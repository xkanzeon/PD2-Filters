ItemDisplay[FL8_ACTIVE FL8_OUTSIDE FL8_UNID (scp OR gsc OR wsp OR 9sc OR 9qs OR 9ws OR 7sc OR 7qs OR 7ws) (MAG OR RARE) !FL8_EXEMPT]:

// Javelins (MAG/RARE): show only (glv OR 9gl OR 7gl OR tsp OR 9ts OR 7ts), hide the rest
ItemDisplay[FL8_ACTIVE FL8_OUTSIDE FL8_UNID (glv OR 9gl OR 7gl OR tsp OR 9ts OR 7ts) (MAG OR RARE) !FL8_EXEMPT]: %NAME%{%NAME%}%CONTINUE%
ItemDisplay[FL8_ACTIVE FL8_OUTSIDE FL8_UNID (jav OR pil OR ssp OR 9ja OR 9pi OR 9s9 OR 7ja OR 7pi OR 7s7) (MAG OR RARE) !FL8_EXEMPT]:

// Spears (MAG/RARE): show only (pik OR 9p9 OR 7p7), hide the rest
