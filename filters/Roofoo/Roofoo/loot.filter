Alias[NOTICEME08]: (WEAPON (MAG OR RARE OR CRAFT) (SUFFIX=594 OR SUFFIX=595) !RW !SHOP !EQUIPPED)
// Life Tap Charges
Alias[NOTICEME09]: (WEAPON (MAG OR RARE OR CRAFT) (SUFFIX=578 OR SUFFIX=579) !RW !SHOP !EQUIPPED)
// High ED Weapon + Mods
Alias[NOTICEME10]: (WEAPON (MAG OR RARE OR CRAFT) ED>349 ((STAT21+STAT22+STAT23+STAT24+STAT159+STAT160>14) OR STAT141>0 OR STAT136>0 OR IAS>29 OR (STAT121+STAT122>50) OR STAT218>0 OR STAT219>0 OR STAT252>0 OR STAT501>285) !SHOP !EQUIPPED)

// Variable socket roll aliases
// Variable sockets: up to 5
// Rune Master - Ettin Axe - Varies: 4-5
Alias[VSOCK501]: (72a UNI SOCK>0 IAS>0 ED>0 STAT44>0 STAT153>0)
// Hellrack - Colossus Crossbow - Varies: 3-5
Alias[VSOCK502]: (6hx UNI SOCK>0 IAS>0 ED>0 STAT333>0 STAT363>0)
// Griswold's Redemption - Caduceus - Varies: 3-5
Alias[VSOCK503]: (7ws SET SOCK>0 IAS>0 ED>0 STAT122>50 !STAT91=0)
// Tomb Reaver - Cryptic Axe - Varies: 3-5
Alias[VSOCK504]: (7pa UNI SOCK>0 IAS>0 ED>0 STAT122>0 RES>0 MFIND>0 STAT86>0 STAT89>0)

// Variable sockets: up to 4
// Bonehew - Ogre Axe - Varies: 2-4
Alias[VSOCK401]: (7o7 UNI SOCK>0 IAS>0 ED>0 STAT117>0 STAT504>0)
// Witchwild String - Short Siege Bow -> Diamond Bow - Varies: 2-4
Alias[VSOCK402]: ((8s8 OR 6s7) UNI SOCK>0 ED>0 RES>0 STAT250>0)
// Black Hades - Chaos Armor -> Shadow Plade - Varies: 3-4
Alias[VSOCK403]: ((xul OR uul) UNI SOCK>0 STAT121>0 STAT123>0 STAT118>0)

// Variable sockets: up to 3
// Blade of Ali Baba - Tulwar -> Hydra Edge - Varies: 2-3
Alias[VSOCK301]: ((9fc OR 7fc) UNI SOCK>0 ED>0 DEX>0 MANA>0 STAT239>0 STAT240>0)
// Djinn Slayer - Ataghan - Varies: 2-3
Alias[VSOCK302]: (7sm UNI SOCK>0 ED>0 STAT121>0 STAT62>0 STAT145>0)
// Achilles Strike - Hurlbat -> Winged Axe - Varies: 2-3
Alias[VSOCK303]: ((9b8 OR 7b8) UNI SOCK>0 TABSK32>0 STR>0 STAT150>0)
// Heaven's Light - Mighty Scepter - Varies: 2-3
Alias[VSOCK304]: (7sc UNI SOCK>0 ED>0 IAS>0 CLSK3>0 STAT116>0 STAT136>0 STAT89>0 STAT139>0)
// Crown of Ages - Corona - Varies: 2-3
Alias[VSOCK305]: (urn UNI SOCK>0 STAT152>0 FHR>0 RES>0 STAT36>0 STAT109>0)
// Denmother - Sun Spirit - Varies: 2-3
Alias[VSOCK306]: (drc UNI SOCK>0 CLSK5>0 FCR>0 GFIND>0 REPLIFE>0)
// Head Hunter's Glory - Troll Nest - Varies: 1-3
Alias[VSOCK307]: (ush UNI SOCK>0 STAT32>0 STAT504>0 STAT86>0)
// Aldur's Rhythm - Jagged Star -> Devil Star - Varies: 1-3
Alias[VSOCK308]: ((9mt OR 7mt) SET SOCK>0 IAS>0 STAT121>0 STAT122>0 STAT62>0 STAT60>0 STAT50>0)
// Griswold's Valor - Corona - Varies: 2-3
Alias[VSOCK309]: (urn SET SOCK>0 ED>0 RES>0 STAT234>0 MFIND>0 !STAT91=0)
// Griswold's Heart - Ornate Plate -> Sacred Armor - Varies: 2-3
Alias[VSOCK310]: ((xar OR uar) SET SOCK>0 CLSK3>0 !STAT91=0 STR>0)
// Griswold's Honor - Vortex Shield - Varies: 2-3
Alias[VSOCK311]: (paf SET SOCK>0 TABSK26>0 FBR>0 STAT20>0 RES>0 FCR>0)
// Natalya's Shadow - Loricated Mail - Varies: 1-3
Alias[VSOCK312]: (ucl SET SOCK>0 TABSK49>0 STAT216>0 STAT110>0)

// Variable sockets: up to 2
// Kalan's Legacy - Mummified Trophy - Varies: 1-2
Alias[VSOCK201]: ((ne6 OR neb) UNI SOCK>0 CLSK2=1 FBR>0 STAT20>0)

// Sound notification rules
// Special item sounds
ItemDisplay[neg UNI !ID !TOWN]: %SOUNDID-913%%NAME%{%NAME%}%CONTINUE% //fallen_warcry_1 - for Sacred Totem "Raaaakanishu!"
ItemDisplay[jew UNI !ID !TOWN]: %SOUNDID-4717%%NAME%{%NAME%}%CONTINUE% //shrine_gemupgrade - for Rainbow Facet
ItemDisplay[(uba OR ubaa OR ubab OR ubac) !TOWN]: %SOUNDID-4609%%NAME%{%NAME%}%CONTINUE% //wussie_let_us_out_2 - for Uber Ancients
ItemDisplay[cm3 UNI !ID !TOWN]: %SOUNDID-3918%%NAME%{%NAME%}%CONTINUE% //gheed_greeting_time_2 - for Gheed's Fortune
// Rune and Larzuk Puzzlepiece sounds
ItemDisplay[RUNE>25 !TOWN]: %SOUNDID-418%%NAME%{%NAME%}%CONTINUE% //cairn_success - for HRs 
ItemDisplay[(RUNE~20-25 OR lpp) !TOWN]: %SOUNDID-248%%NAME%{%NAME%}%CONTINUE% //item_whip - for Mid Runes an Larzuk Puzzlepiece
// Uber and super-rare unique sounds
ItemDisplay[(PD2UBERUNI1 OR PD2UBERUNI2) !TOWN]: %SOUNDID-27%%NAME%{%NAME%}%CONTINUE% //quest_anyasteam - for Uber Items
// Enpherno Bastard meme drop sound
ItemDisplay[(ENPHBASTARD) !TOWN]: %SOUNDID-4610%%NAME%{%NAME%}%CONTINUE% //D1 Warp Death Sound
// Three-star pickup item sounds
ItemDisplay[(TPUNIETH1 OR TPUNIETH2 OR TPUNI1 OR TPUNI2 OR TPSETETH1 OR TPSET1) !TOWN]: %SOUNDID-34%%NAME%{%NAME%}%CONTINUE% //PoE Drop
// Three-star item sounds
ItemDisplay[(TSUNIETH1 OR TSUNIETH2 OR TSUNI1 OR TSUNI2 OR TSSETETH1 OR TSSET1) !TOWN]: %SOUNDID-35%%NAME%{%NAME%}%CONTINUE% //PoE Drop
// One-star item sounds
ItemDisplay[(OSUNIETH1 OR OSUNIETH2 OR OSUNIETH3 OR OSUNI1 OR OSUNI2 OR OSUNI3 OR OSUNI4 OR OSSETETH1 OR OSSET1) !TOWN]: %NAME%{%NAME%}%CONTINUE%
// Super-rare item sounds
ItemDisplay[(llmr OR lsvl OR rkey OR rid OR rtp) !TOWN]: %SOUNDID-619%%NAME%{%NAME%}%CONTINUE% //bloodraven_mist_begin - for Super Rares like Lilith Mirror
// Rare material sounds
ItemDisplay[(lbox OR imrn) !TOWN]: %SOUNDID-621%%NAME%{%NAME%}%CONTINUE% //bloodraven_mist_end - for Rares lbox, demonic cube etc.
// Uber material sounds
ItemDisplay[(ubtm OR dcma OR dcso OR dcbl OR dcho OR rtma OR rtmv OR rtmo OR cm2f OR rtmf OR luca OR lucb OR lucc OR lucd) !TOWN]: %SOUNDID-1123%%NAME%{%NAME%}%CONTINUE% //greatermummy_resurrect_1 - for Uber Ingredients
// Unique map sounds
ItemDisplay[MAPTIER>0 !ID UNI]: %SOUNDID-35%%NAME%{%NAME%}%CONTINUE% //hellforgesmash - for unique maps

