ItemDisplay[NMAG !ID SHOP MAPID>132]: %NAME%%NL%%NL%%TAN%Note%WHITE%: Possible Uniques:

// Non-magic item tooltip bracket
// Start non-magic item tooltip bracket
ItemDisplay[ETH OR (DIN NMAG !RW RES>0) OR (DIN NMAG !RW EDAM>0) OR ((AMASTAFF OR NECSTAFF OR ASNSTAFF OR BARSTAFF OR DRUSTAFF OR PALSTAFF OR SORSTAFF) NMAG !RW) OR EDARMOR OR EDWEAPON !SUP !INF]: %GRAY%] %NAME%%CONTINUE%
ItemDisplay[ETH OR (DIN NMAG !RW RES>0) OR (DIN NMAG !RW EDAM>0) OR ((AMASTAFF OR NECSTAFF OR ASNSTAFF OR BARSTAFF OR DRUSTAFF OR PALSTAFF OR SORSTAFF) NMAG !RW) OR EDARMOR OR EDWEAPON (SUP OR INF)]: %GRAY%]%NAME%%CONTINUE%
// Add ethereal tag to non-magic item notes
ItemDisplay[ETH]: %WHITE%eth%NAME%%CONTINUE%
ItemDisplay[ETH AND ((DIN NMAG !RW RES>0) OR (DIN NMAG !RW EDAM>0) OR EDARMOR OR EDWEAPON)]: %GRAY%|%NAME%%CONTINUE%
ItemDisplay[ETH AND (((AMASTAFF EDAM=0) OR NECSTAFF OR ASNSTAFF OR BARSTAFF OR DRUSTAFF OR PALSTAFF OR SORSTAFF) NMAG !RW)]: %GRAY%|%NAME%%CONTINUE%
// Paladin shield base notes
// Add exact resist value to Paladin shields
ItemDisplay[DIN NMAG !RW RES>0 AND RES<20]: %TAN%%RES%%WHITE%r%NAME%%CONTINUE%
ItemDisplay[DIN NMAG !RW RES>19 AND RES<25]: %DARK_GREEN%%RES%%WHITE%r%NAME%%CONTINUE%
ItemDisplay[DIN NMAG !RW RES>24]: %GREEN%%RES%%WHITE%r%NAME%%CONTINUE%
// Add ED tag to Paladin shields
ItemDisplay[DIN NMAG !RW EDAM>0 AND EDAM<51]: %EDAM%%WHITE%ed%NAME%%CONTINUE%
ItemDisplay[DIN NMAG !RW EDAM>50]: %RED%%EDAM%%WHITE%ed%NAME%%CONTINUE%  
// End Paladin shield base notes
ItemDisplay[((DIN NMAG !RW RES>0) OR (DIN NMAG !RW EDAM>0)) AND (((AMASTAFF OR NECSTAFF OR ASNSTAFF OR BARSTAFF OR DRUSTAFF OR PALSTAFF OR SORSTAFF) NMAG !RW) OR EDARMOR OR EDWEAPON)]: %GRAY%|%NAME%%CONTINUE%
// Staffmod tooltip details
// Add exact +skill values to non-magic class items
// Amazon
ItemDisplay[NMAG !RW TABSK0~1-2 AMAZON]: %LIGHT_GRAY%%TABSK0%%SAGE%bow%NAME%%CONTINUE%
ItemDisplay[NMAG !RW TABSK0>2 AMAZON]: %ORANGE%+%YELLOW%%TABSK0%%SAGE%bow%NAME%%CONTINUE%
ItemDisplay[NMAG !RW TABSK2~1-2 AMAZON]: %LIGHT_GRAY%%TABSK2%%SAGE%jav%NAME%%CONTINUE%
ItemDisplay[NMAG !RW TABSK2>2 AMAZON]: %ORANGE%+%YELLOW%%TABSK2%%SAGE%jav%NAME%%CONTINUE%
ItemDisplay[NMAG !RW TABSK0~1-2 !AMAZON]: %LIGHT_GRAY%%TABSK0%%DARK_GREEN%bow%NAME%%CONTINUE%
ItemDisplay[NMAG !RW TABSK0>2 !AMAZON]: %ORANGE%+%YELLOW%%TABSK0%%DARK_GREEN%bow%NAME%%CONTINUE%
ItemDisplay[NMAG !RW TABSK2~1-2 !AMAZON]: %LIGHT_GRAY%%TABSK2%%DARK_GREEN%jav%NAME%%CONTINUE%
ItemDisplay[NMAG !RW TABSK2>2 !AMAZON]: %ORANGE%+%YELLOW%%TABSK2%%DARK_GREEN%jav%NAME%%CONTINUE%

// Necromancer
ItemDisplay[NMAG !RW SK374>0 NECROMANCER]: %SAGE%cum%NAME%%CONTINUE%
ItemDisplay[NMAG !RW SK374>0 !NECROMANCER]: %DARK_GREEN%cum%NAME%%CONTINUE%
