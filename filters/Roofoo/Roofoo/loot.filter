ItemDisplay[GOLD<100 (CLVL>11 OR FILTLVL>5)]:
ItemDisplay[GOLD<200 (CLVL>23 OR FILTLVL>5)]:
ItemDisplay[GOLD<400 (CLVL>39 OR FILTLVL>5)]:
ItemDisplay[GOLD<1000 CLVL>79]:
ItemDisplay[GOLD<2000 CLVL>79 FILTLVL>1]:
ItemDisplay[GOLD<3000 CLVL>79 FILTLVL>5]:
ItemDisplay[GOLD<5000 CLVL>79 FILTLVL>7]:

// Shorten superior/inferior base names before later tags are added
ItemDisplay[(ARMOR OR WEAPON OR QUIVER) (SUP OR INF) !RW]: %BASENAME%%CONTINUE%

// Base item color pass
ItemDisplay[UNI]: %GOLD%%NAME%%CONTINUE%
ItemDisplay[SET]: %GREEN%%NAME%%CONTINUE%
ItemDisplay[RARE]: %YELLOW%%NAME%%CONTINUE%
ItemDisplay[MAG]: %BLUE%%NAME%%CONTINUE%
ItemDisplay[(ARMOR OR WEAPON OR QUIVER) NMAG !ETH SOCK=0]: %WHITE%%NAME%%CONTINUE%
ItemDisplay[(ARMOR OR WEAPON OR QUIVER) NMAG (SOCK>0 OR ETH)]: %GRAY%%NAME%%CONTINUE%
ItemDisplay[CRAFT]: %ORANGE%%NAME%%CONTINUE%

// Stygian Caverns corruption marker
ItemDisplay[(ARMOR OR WEAPON OR (QUIVER OR rin OR amu)) (MAG OR RARE OR SET OR UNI OR CRAFT) !ID (MAPID=181 OR MAPID=182)]: %RED%*%NAME%%RED%*%CONTINUE%

// City of Ureh unknown-socket marker
ItemDisplay[((CHEST OR HELM OR CIRC OR SHIELD OR QUIVER) OR WEAPON) !THROWPOTS (MAG OR RARE OR CRAFT OR UNI OR SET) !ID (MAPID=195 OR MAPID=196)]: %NAME% %TAN%[%WHITE%?%TAN%]%CONTINUE%

// Superior and inferior name prefixes
ItemDisplay[SUP ED<5]: %WHITE%Sup %NAME%%CONTINUE%
ItemDisplay[WEAPON SUP ED>4]: %CORAL%Sup %NAME%%CONTINUE%
ItemDisplay[ARMOR SUP ED>4]: %TEAL%Sup %NAME%%CONTINUE%
ItemDisplay[INF !(rin OR amu) ID]: %GRAY%Inf %NAME%%CONTINUE%

// Gambling screen item names
ItemDisplay[(WEAPON OR ARMOR) NMAG !ID SHOP MAPID<133]: %NAME%

