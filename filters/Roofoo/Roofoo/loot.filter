// Filter level names shown in the in-game strictness menu
ItemDisplayFilterName[]: Hide Just Trash Items
ItemDisplayFilterName[]: More Notify
ItemDisplayFilterName[]: More Notify - w/o Potions
ItemDisplayFilterName[]: Recommended
ItemDisplayFilterName[]: Recommended - w/o Potions
ItemDisplayFilterName[]: Strict Filter
ItemDisplayFilterName[]: Strict Filter - w/o Potions
ItemDisplayFilterName[]: Max-Strictness Filter - Ultra Strict End Game

// Horadric Cube tooltip shows filter credits and the active filter level
ItemDisplay[box]:%NAME%{%NAME%%NL%%GRAY%item.filter ver 13.0.2 %BLACK%| %GRAY% updated: 2026-04-30%NL%%PURPLE%The GOAT OG Author %WHITE%-%SAGE% Kryszard%NL%%ORANGE%Editors %WHITE%-%SAGE% RoofooEvazan & Enpherno}%CONTINUE%
ItemDisplay[box FILTLVL=0]: %NAME%{%NAME%%NL%%WHITE%You Can Change it in Settings%NL%0 - %TAN%Show All Items%NL%%TAN% Note%WHITE%: Roofoo's PD2 Loot-Filter level:%NL%}
ItemDisplay[box FILTLVL=1]: %NAME%{%NAME%%NL%%WHITE%You Can Change it in Settings%NL%1 - %TAN%Hide Just Trash Items%NL%%TAN% Note%WHITE%: Roofoo's PD2 Loot-Filter level:%NL%}
ItemDisplay[box FILTLVL=2]: %NAME%{%NAME%%NL%%WHITE%You Can Change it in Settings%NL%2 - %TAN%More Notify%NL%%TAN% Note%WHITE%: Roofoo's PD2 Loot-Filter level:%NL%}
ItemDisplay[box FILTLVL=3]: %NAME%{%NAME%%NL%%WHITE%You Can Change it in Settings%NL%3 - %TAN%More Notify %WHITE%- %RED%w/o Potions%NL%%TAN% Note%WHITE%: Roofoo's PD2 Loot-Filter level:%NL%}
ItemDisplay[box FILTLVL=4]: %NAME%{%NAME%%NL%%WHITE%You Can Change it in Settings%NL%4 - %TAN%Recommended%NL%%TAN% Note%WHITE%: Roofoo's PD2 Loot-Filter level:%NL%}
ItemDisplay[box FILTLVL=5]: %NAME%{%NAME%%NL%%WHITE%You Can Change it in Settings%NL%5 - %TAN%Recommended %WHITE%- %RED%w/o Potions%NL%%TAN% Note%WHITE%: Roofoo's PD2 Loot-Filter level:%NL%}
ItemDisplay[box FILTLVL=6]: %NAME%{%NAME%%NL%%WHITE%You Can Change it in Settings%NL%6 - %ORANGE%Strict Filter%NL%%TAN% Note%WHITE%: Roofoo's PD2 Loot-Filter level:%NL%}
ItemDisplay[box FILTLVL=7]: %NAME%{%NAME%%NL%%WHITE%You Can Change it in Settings%NL%7 - %ORANGE%Strict Filter %WHITE%- %RED%w/o Potions%NL%%TAN% Note%WHITE%: Roofoo's PD2 Loot-Filter level:%NL%}
ItemDisplay[box FILTLVL=8]: %NAME%{%NAME%%NL%%WHITE%You Can Change it in Settings%NL%8 - %RED%Max-Strictness Filter %WHITE%- %RED%Ultra Strict End Game%NL%%TAN% Note%WHITE%: Roofoo's PD2 Loot-Filter level:%NL%}

// ===============================
// FILTER LEVEL 8 STRICT HIDES
// ===============================
// My strictest filter level:
//  - Sets, uniques, and Runewords always pass through.
//  - Identified magic and rare items stay visible; later rules handle formatting.
//  - Town/shop keeps unid gear visible so I can browse and compare.
//  - Outside town, unid items use the strict hide/show lists below.
//  - Show rules continue into the normal formatting sections.
//  - Hide rules blank the item name.
// Each strict rule stays on one line for parser safety.

// FL8 guard aliases
Alias[FL8_ACTIVE]: (FILTLVL=8)
Alias[FL8_EXEMPT]: (UNI OR SET OR RW)
Alias[FL8_INTOWN]: (TOWN OR SHOP)
Alias[FL8_OUTSIDE]: (!TOWN !SHOP)
Alias[FL8_UNID]: (!ID)
Alias[FL8_ID_MR]: (ID (MAG OR RARE))

// FL8 quick-pass rules
ItemDisplay[FL8_ACTIVE FL8_EXEMPT]: %NAME%{%NAME%}%CONTINUE%
ItemDisplay[FL8_ACTIVE FL8_ID_MR !FL8_EXEMPT]: %NAME%{%NAME%}%CONTINUE%
ItemDisplay[FL8_ACTIVE FL8_INTOWN !FL8_EXEMPT]: %NAME%{%NAME%}%CONTINUE%

// FL8 high-affix rare non-eth chest/shield bases with 4os potential
ItemDisplay[FL8_ACTIVE (CHEST OR SHIELD) RARE !ETH !ID (ALVL>74 OR CRAFTALVL>74) MAXSOCKETS=4]: %DOT-A8%%TIER-7%%NAME%

// ===============================
// FL8 outside-town unid hide/show rules
// ===============================

// FL8 unid armor bases outside town

// Helms: SHOW only (urn OR uhm OR uh9 OR usk) with ED>10 and (SOCK=0 OR SOCK=3)
ItemDisplay[FL8_ACTIVE FL8_OUTSIDE (urn OR uhm OR uh9 OR usk) (NMAG OR SUP) ED>10 (SOCK=0 OR SOCK=3) !FL8_EXEMPT]: %NAME%{%NAME%}%CONTINUE%
ItemDisplay[FL8_ACTIVE FL8_OUTSIDE (urn OR uhm OR uh9 OR usk) (NMAG OR SUP) !(ED>10 (SOCK=0 OR SOCK=3)) !FL8_EXEMPT]:
ItemDisplay[FL8_ACTIVE FL8_OUTSIDE (cap OR skp OR hlm OR fhl OR msk OR bhm OR ghm OR crn OR xap OR xkp OR xlm OR xhl OR xsk OR xh9 OR xhm OR xrn OR uap OR ukp OR ulm OR uhl) (NMAG OR SUP OR INF) !FL8_EXEMPT]:

// Circlets (white): SHOW only Diadem (ci3) NMAG !SUP SOCK=0 ; hide other circlets
ItemDisplay[FL8_ACTIVE FL8_OUTSIDE ci3 NMAG !SUP SOCK=0 !FL8_EXEMPT]: %NAME%{%NAME%}%CONTINUE%
ItemDisplay[FL8_ACTIVE FL8_OUTSIDE (ci0 OR ci1 OR ci2) NMAG !FL8_EXEMPT]:

// Chest: SHOW listed elites with ED>10 and (SOCK=0 OR SOCK=3 OR SOCK=4)
ItemDisplay[FL8_ACTIVE FL8_OUTSIDE (gth OR aar OR xng OR uui OR uea OR ula OR utu OR ung OR ucl OR uhn OR urs OR upl OR ult OR uld OR uth OR utp OR uul OR uar) (NMAG OR SUP) ED>10 (SOCK=0 OR SOCK=3 OR SOCK=4) !FL8_EXEMPT]: %NAME%{%NAME%}%CONTINUE%
ItemDisplay[FL8_ACTIVE FL8_OUTSIDE (gth OR aar OR xng OR uui OR uea OR ula OR utu OR ung OR ucl OR uhn OR urs OR upl OR ult OR uld OR uth OR utp OR uul OR uar) (NMAG OR SUP) !(ED>10 (SOCK=0 OR SOCK=3 OR SOCK=4)) !FL8_EXEMPT]:
ItemDisplay[FL8_ACTIVE FL8_OUTSIDE (qui OR lea OR hla OR stu OR rng OR scl OR chn OR brs OR spl OR plt OR fld OR ltp OR ful OR xui OR xea OR xla OR xtu OR xcl OR xhn OR xrs OR xpl OR xlt OR xld OR xth OR xtp OR xul OR xar) (NMAG OR SUP OR INF) !FL8_EXEMPT]:

// Non-Pally Shields: SHOW (uit OR uow) with ED>10, NON-ETH, (SOCK=0 OR SOCK=4)
ItemDisplay[FL8_ACTIVE FL8_OUTSIDE (uit OR uow) (NMAG OR SUP) ED>10 !ETH (SOCK=0 OR SOCK=4) !FL8_EXEMPT]: %NAME%{%NAME%}%CONTINUE%
ItemDisplay[FL8_ACTIVE FL8_OUTSIDE (uit OR uow) (NMAG OR SUP) !(ED>10 !ETH (SOCK=0 OR SOCK=4)) !FL8_EXEMPT]:
ItemDisplay[FL8_ACTIVE FL8_OUTSIDE (bux OR sml OR lrg OR spk OR kit OR bah OR tow OR gts OR xuc OR xml OR xrg OR xpk OR xit OR xsh OR xow OR xts OR uuc OR uml OR urg OR upk OR ush OR uts) (NMAG OR SUP OR INF) !FL8_EXEMPT]:

// Pally Shields: SHOW (pad OR pae OR paf) with ED>10 and (SOCK=0 OR SOCK=3 OR SOCK=4) and (ED>60 OR RES>25)
ItemDisplay[FL8_ACTIVE FL8_OUTSIDE (pad OR pae OR paf) (NMAG OR SUP) ED>10 (SOCK=0 OR SOCK=3 OR SOCK=4) (ED>60 OR RES>25) !FL8_EXEMPT]: %NAME%{%NAME%}%CONTINUE%
ItemDisplay[FL8_ACTIVE FL8_OUTSIDE (pad OR pae OR paf) (NMAG OR SUP) !(ED>10 (SOCK=0 OR SOCK=3 OR SOCK=4) (ED>60 OR RES>25)) !FL8_EXEMPT]:
ItemDisplay[FL8_ACTIVE FL8_OUTSIDE (pa1 OR pa2 OR pa3 OR pa4 OR pa5 OR pa6 OR pa7 OR pa8 OR pa9 OR paa OR pab OR pac) (NMAG OR SUP OR INF) !FL8_EXEMPT]:

// FL8 base hides for gloves, boots, belts, class helms, and class shields
ItemDisplay[FL8_ACTIVE FL8_OUTSIDE (lgl OR vgl OR mgl OR tgl OR hgl OR xlg OR xvg OR xmg OR xtg OR xhg OR ulg OR uvg OR umg OR utg OR uhg) (NMAG OR SUP OR INF) !FL8_EXEMPT]:
ItemDisplay[FL8_ACTIVE FL8_OUTSIDE (lbt OR vbt OR mbt OR tbt OR hbt OR xlb OR xvb OR xmb OR xtb OR xhb OR ulb OR uvb OR umb OR utb OR uhb) (NMAG OR SUP OR INF) !FL8_EXEMPT]:
