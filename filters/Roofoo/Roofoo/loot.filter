// FL8 unid weapon bases outside town

// Axes (bases): SHOW only Ettin Axe (72a) with ED>10 ETH and (SOCK=0 OR SOCK=5)
ItemDisplay[FL8_ACTIVE FL8_OUTSIDE 72a (NMAG OR SUP) ETH ED>10 (SOCK=0 OR SOCK=5) !FL8_EXEMPT]: %NAME%{%NAME%}%CONTINUE%
