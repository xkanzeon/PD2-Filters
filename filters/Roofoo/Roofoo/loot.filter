// 0 = no star display tier
Alias[NSUNI1]: ((6hx OR 72a OR 7b8 OR 7bk OR 7bt OR 7gs OR 7sp OR 7sr OR 7st OR 7vo OR 9gm OR 9gw OR 9kr OR 9s8 OR 9wc OR ama OR amc OR gix) UNI !ETH !ID)
Alias[NSUNI2]: ((hbt OR ltp OR mbt OR obd OR ulb OR umb OR ung OR upk OR urg OR ush OR uvb OR xar OR xhm OR xth OR xtp OR xul OR zvb) UNI !ETH !ID)
