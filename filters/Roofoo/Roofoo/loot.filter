// End staffmod tooltip details
ItemDisplay[(NMAG !RW AMASTAFF) AND (EDARMOR OR EDWEAPON)]: %GRAY%|%NAME%%CONTINUE%
// Add socket count to socketed items
// Socket count tooltip details
ItemDisplay[SOCK>0]: %NAME% %TAN%[%WHITE%%SOCKETS%%CONTINUE%
// Variable socket roll aliases
// Variable sockets: up to 5
ItemDisplay[(VSOCK501 OR VSOCK502 OR VSOCK503 OR VSOCK504)]: %NAME%%GRAY%/%LIGHT_GRAY%5%CONTINUE%
// Variable sockets: up to 4
ItemDisplay[(VSOCK401 OR VSOCK402 OR VSOCK403)]: %NAME%%GRAY%/%LIGHT_GRAY%4%CONTINUE%
// Variable sockets: up to 3
ItemDisplay[(VSOCK301 OR VSOCK302 OR VSOCK303 OR VSOCK304 OR VSOCK305 OR VSOCK306 OR VSOCK307 OR VSOCK308 OR VSOCK309 OR VSOCK310 OR VSOCK311 OR VSOCK312)]: %NAME%%GRAY%/%LIGHT_GRAY%3%CONTINUE%
// Variable sockets: up to 2
ItemDisplay[(VSOCK201)]: %NAME%%GRAY%/%LIGHT_GRAY%2%CONTINUE%
// End socket count tooltip details
ItemDisplay[SOCK>0]: %NAME%%TAN%]%CONTINUE%
// Armors ED TAG
ItemDisplay[EDARMOR]: %BLUE%%ED%%%NAME%%CONTINUE%
ItemDisplay[EDARMOR !RW]: %NAME% %BLUE%*%CONTINUE%
// Weapons ED TAG
ItemDisplay[EDWEAPON]: %RED%%ED%%%NAME%%CONTINUE%
ItemDisplay[EDWEAPON !RW]: %NAME% %RED%*%CONTINUE%
// End non-magic item tooltip bracket
ItemDisplay[ETH OR (DIN NMAG !RW RES>0) OR (DIN NMAG !RW EDAM>0) OR ((AMASTAFF OR NECSTAFF OR ASNSTAFF OR BARSTAFF OR DRUSTAFF OR PALSTAFF OR SORSTAFF) NMAG !RW) OR EDARMOR OR EDWEAPON]: %GRAY%[%NAME%%CONTINUE%

// Health & Mana & Rejuvenation Potions
ItemDisplay[rvl]: %PURPLE%R %WHITE%Full{%WHITE%Full Rejuvenation Potion}%CONTINUE%
ItemDisplay[rvs]: %PURPLE%r %WHITE%35%{%PURPLE%r %WHITE%35%, Perf %YELLOW%O%WHITE%, %BLUE%Ring %WHITE%= Light Res %BLUE%Ring%NL%%WHITE%3x %PURPLE%r %WHITE%35% = %PURPLE%R%WHITE% Full%NL%%TAN% Note%WHITE%: Crafting Recipes:%NL%Rejuvenation Potion}%CONTINUE%
ItemDisplay[rvs FILTLVL>7]: {%NAME%}%CONTINUE%
ItemDisplay[hp5]: %RED%!%WHITE%Hp{%WHITE%Super Healing Potion}%CONTINUE%
ItemDisplay[mp5]: %BLUE%!%WHITE%Mp{%WHITE%Super Mana Potion}%CONTINUE%
ItemDisplay[hp1]: %RED%!%WHITE%minor hp{%WHITE%Minor Healing Potion}%CONTINUE%
ItemDisplay[hp2]: %RED%!%WHITE%light hp{%WHITE%Light Healing Potion}%CONTINUE%
ItemDisplay[hp3]: %RED%!%WHITE%healing{%WHITE%Healing Potion}%CONTINUE%
ItemDisplay[hp4]: %RED%!%WHITE%great hp{%WHITE%Greater Healing Potion}%CONTINUE%
ItemDisplay[mp1]: %BLUE%!%WHITE%minor mp{%WHITE%Minor Mana Potion}%CONTINUE%
ItemDisplay[mp2]: %BLUE%!%WHITE%light mp{%WHITE%Light Mana Potion}%CONTINUE%
ItemDisplay[mp3]: %BLUE%!%WHITE%mana{%WHITE%Mana Potion}%CONTINUE%
ItemDisplay[mp4]: %BLUE%!%WHITE%great mp{%WHITE%Greater Mana Potion}%CONTINUE%
ItemDisplay[(hp1 OR hp2 OR hp3 OR mp1 OR mp2 OR mp3) ((FILTLVL>0 DIFF>0) OR (FILTLVL=3 OR FILTLVL=5 OR FILTLVL>6)) !SHOP]: {%NAME%}
ItemDisplay[(hp4 OR mp4) ((FILTLVL>0 DIFF>1) OR (FILTLVL=3 OR FILTLVL=5 OR FILTLVL>6)) !SHOP]: {%NAME%}
ItemDisplay[(hp5 OR mp5) (FILTLVL=3 OR FILTLVL=5 OR FILTLVL>6) !SHOP]: {%NAME%}

// Utilities
ItemDisplay[tsc]: %BLUE%* %GRAY%tp %WHITE%scroll{%RED%Warning%WHITE%: You gonna lose socketed Runes/Gems/Jewels%NL%Socketed Item, %BLUE%* %GRAY%tp %WHITE%scroll, %ORANGE%Hel%NL%%TAN%Note%WHITE%: To remove Runes/Gems/Jewels from Item:%NL%Scroll of Town Portal}%CONTINUE%
ItemDisplay[isc]: %RED%* %GRAY%id %WHITE%scroll{%WHITE%Scroll of Identify}%CONTINUE%
ItemDisplay[vps]: %GREEN%!%WHITE%stamina{%GRAY%(time stack)%NL%%WHITE%Gives infinite stamina for 30s%NL%%TAN%Note%WHITE%: Instantly restores stamina%NL%Stamina Potion}%CONTINUE%
ItemDisplay[wms]: %GREEN%!%WHITE%thaw{%GREEN%!%WHITE%thaw, Perf %BLUE%O%WHITE%, %BLUE%Ring %WHITE%= Cold Res %BLUE%Ring%NL%%GRAY%(time stack)%NL%%WHITE%Gives +25 Cold Res for 30s%NL%%TAN%Note%WHITE%: Instantly thaws character%NL%Thawing Potion}%CONTINUE%
ItemDisplay[(tsc OR isc OR vps) FILTLVL>0 (CLVL>30 OR FILTLVL>5) !SHOP]: {%NAME%}%CONTINUE%
ItemDisplay[wms FILTLVL>0 (CHARSTAT118>1 OR CHARSTAT153>0) !SHOP]: {%NAME%}%CONTINUE%
ItemDisplay[yps]: %GREEN%!%WHITE%ant{%GREEN%!%WHITE%ant, Perf %GREEN%O%WHITE%, %BLUE%Ring %WHITE%= Psn Res %BLUE%Ring%NL%%GRAY%(time stack)%NL%%WHITE%Gives +25 Psn Res for 30s%NL%%TAN%Note%WHITE%: Instantly cures poison%NL%Antidote Potion}

// keys
ItemDisplay[key]: %GRAY%key%CONTINUE%
//

// Craft Infusions
ItemDisplay[(crfb OR crfc OR crfs OR crfh OR crfv OR crfu OR crfp)]: %NAME%{%TAN%Note%WHITE%: Guaranteed:}%CONTINUE%
//
ItemDisplay[key FILTLVL>0 ((ASSASSIN DIFF>0) OR FILTLVL>5) !TOWN]: {%NAME%}
//
ItemDisplay[rkey (TOWN OR MAPID>132)]: %NAME%{%TAN%Note%WHITE%: You won't lose it in Cube recipes}%CONTINUE%

// Choking, Exploding, Fulminating, Oil, Rancid, Strangling, and New PD2 Throwing Potions
ItemDisplay[opm OR tpfm]: %NAME%{%WHITE%Exoplo. Potion, Perf %RED%O%WHITE%, %BLUE%Ring %WHITE%= Fire Res %BLUE%Ring%NL%%TAN%Note%WHITE%: Crafting Recipe:}%CONTINUE%
ItemDisplay[(opm OR tpfm) FILTLVL>0 (CLVL>79 OR FILTLVL>5)]: {%NAME%}
ItemDisplay[(gpm OR opl OR ops OR gps OR gpl) FILTLVL>0 (CLVL>23 OR FILTLVL>5)]: {%NAME%}
ItemDisplay[(tpfs OR tpgs OR tpcs OR tpls) FILTLVL>0 (CLVL>17 OR FILTLVL>5)]: {%NAME%}
ItemDisplay[(tpfm OR tpgm OR tpcm OR tplm) FILTLVL>0 (CLVL>23 OR FILTLVL>5)]: {%NAME%}
ItemDisplay[(tpfl OR tpgl OR tpcl OR tpll) FILTLVL>0 (CLVL>39 OR FILTLVL>5)]: {%NAME%}

