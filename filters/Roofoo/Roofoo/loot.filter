ItemDisplay[(skzs OR skz)]: %NAME%{%NAME%%WHITE%You Can use %BLUE%Magic%WHITE%/%YELLOW%Rare %WHITE%Items as Bases%NL%Gloves: %ORANGE%Io %BLACK%| %WHITE%Belt: %ORANGE%Eld %BLACK%| %WHITE%Boots: %ORANGE%El%NL%%WHITE%Weapon: %ORANGE%Shael %BLACK%| %WHITE%Chest: %ORANGE%Tir %BLACK%| %WHITE%Shield/Quiver: %ORANGE%Sol%NL%%WHITE%Ring: %ORANGE%Hel %BLACK%| %WHITE%Helm: %ORANGE%Lum %BLACK%| %WHITE%Amulet: %ORANGE%Dol%NL%%TAN%Note%WHITE%: Vampiric Crafting Recipes: Perf %GRAY%O%WHITE%, %BLUE%Jewel%WHITE%,}%CONTINUE%
ItemDisplay[gpv OR gpy OR gpb OR gpg OR gpr OR gpw OR skz]: %NAME%{%NAME%%NL%}%CONTINUE%
// amethysts
ItemDisplay[GEMTYPE=1 GEM<4 !(gzv OR gpv)]: %NAME% %ORANGE%[%PURPLE%*%ORANGE%]{%NAME%}%CONTINUE%
ItemDisplay[GEMTYPE=1 GEM>3]: %NAME% %ORANGE%[%PURPLE%O%ORANGE%]{%NAME%}%CONTINUE%
// diamonds
ItemDisplay[GEMTYPE=2 GEM<4 !(glw OR gpw)]: %NAME% %ORANGE%[%WHITE%*%ORANGE%]{%NAME%}%CONTINUE%
ItemDisplay[GEMTYPE=2 GEM>3]: %NAME% %ORANGE%[%WHITE%O%ORANGE%]{%NAME%}%CONTINUE%
// emeralds
ItemDisplay[GEMTYPE=3 GEM<4 !(glg OR gpg)]: %NAME% %ORANGE%[%GREEN%*%ORANGE%]{%NAME%}%CONTINUE%
ItemDisplay[GEMTYPE=3 GEM>3]: %NAME% %ORANGE%[%GREEN%O%ORANGE%]{%NAME%}%CONTINUE%
// rubys
ItemDisplay[GEMTYPE=4 GEM<4 !(glr OR gpr)]: %NAME% %ORANGE%[%RED%*%ORANGE%]{%NAME%}%CONTINUE%
ItemDisplay[GEMTYPE=4 GEM>3]: %NAME% %ORANGE%[%RED%O%ORANGE%]{%NAME%}%CONTINUE%
// sapphires
ItemDisplay[GEMTYPE=5 GEM<4 !(glb OR gpb)]: %NAME% %ORANGE%[%BLUE%*%ORANGE%]{%NAME%}%CONTINUE%
ItemDisplay[GEMTYPE=5 GEM>3]: %NAME% %ORANGE%[%BLUE%O%ORANGE%]{%NAME%}%CONTINUE%
// topazes
ItemDisplay[GEMTYPE=6 GEM<4 !(gly OR gpy)]: %NAME% %ORANGE%[%YELLOW%*%ORANGE%]{%NAME%}%CONTINUE%
ItemDisplay[GEMTYPE=6 GEM>3]: %NAME% %ORANGE%[%YELLOW%O%ORANGE%]{%NAME%}%CONTINUE%
// skulls
ItemDisplay[GEMTYPE=7 GEM<4 !(skl OR skz)]: %NAME% %ORANGE%[%GRAY%*%ORANGE%]{%NAME%}%CONTINUE%
ItemDisplay[GEMTYPE=7 GEM>3]: %NAME% %ORANGE%[%GRAY%O%ORANGE%]{%NAME%}%CONTINUE%
// hiding low ones
ItemDisplay[GEM<3 FILTLVL>0 (DIFF>0 OR FILTLVL>5) !(gzv OR gpv OR glw OR gpw OR glg OR gpg OR glr OR gpr OR glb OR gpb OR gly OR gpy OR skl OR skz)]:{%NAME%}%CONTINUE%
ItemDisplay[GEM<4 FILTLVL>0 (DIFF>1 OR FILTLVL>5) !(gzv OR gpv OR glw OR gpw OR glg OR gpg OR glr OR gpr OR glb OR gpb OR gly OR gpy OR skl OR skz)]:{%NAME%}%CONTINUE%
// ping for flawlesses and perfects
ItemDisplay[(skls)]: %DOT-70%%TIER-3%%NAME%{%NAME%}%CONTINUE%
ItemDisplay[(gzvs OR glys OR glbs OR glgs OR glrs OR glws) FILTLVL<8]: %DOT-70%%TIER-3%%NAME%{%NAME%}%CONTINUE%
ItemDisplay[(gpvs OR gpys OR gpbs OR gpgs OR gprs OR gpws OR skzs)]: %DOT-70%%NAME%{%NAME%}%CONTINUE%

// Hide Flawlesses on Max Strict Level
ItemDisplay[(GEM<4 OR (gzvs OR glys OR glbs OR glgs OR glrs OR glws)) FILTLVL>7]:{%NAME%}%CONTINUE%

// Rune appearance
ItemDisplay[RUNE<18]: %ORANGE%%RUNENAME% %GRAY%[%TAN%%RUNENUM%%GRAY%]{%NAME%}%CONTINUE%
ItemDisplay[RUNE~18-19]: %ORANGE%%RUNENAME% Rune %GRAY%[%TAN%%RUNENUM%%GRAY%]{%NAME%}%CONTINUE%
ItemDisplay[RUNE~20-25]: %ORANGE%%RUNENAME% Rune %GRAY%[%RED%%RUNENUM%%GRAY%]{%NAME%}%CONTINUE%
ItemDisplay[RUNE>25]: %ORANGE%%RUNENAME% Rune %GRAY%[%GREEN%%RUNENUM%%GRAY%]{%NAME%}%CONTINUE%

// All Charms
// 1) Filter level 8+: hide sub-90 unid magic GCs
ItemDisplay[(cm1 OR cm2 OR cm3) MAG !ID (ILVL<90) (FILTLVL>7)]: {%NAME%}

// 2) Filter level 8+: special display for ilvl 90+ unid magic GCs
ItemDisplay[(cm1) MAG !ID (ILVL>89) (FILTLVL>7)]: %DOT-9B%%BLUE%*%BLUE%*%BLUE%*    %TEAL%Small Charm   %BLUE%*%BLUE%*%BLUE%*
ItemDisplay[(cm2) MAG !ID (ILVL>89) (FILTLVL>7)]: %DOT-9B%%BLUE%*%BLUE%*%BLUE%*    %TEAL%Large Charm    %BLUE%*%BLUE%*%BLUE%*
ItemDisplay[(cm3) MAG !ID (ILVL>89) (FILTLVL>7)]: %DOT-9B%%BLUE%*%BLUE%*%BLUE%*    %TEAL%Grand Charm    %BLUE%*%BLUE%*%BLUE%*

// Filter levels below 8: show sub-90 unid magic GCs with a basic name
ItemDisplay[(cm1) MAG !ID (ILVL<90) (FILTLVL<8)]: %DOT-9B%%BLUE%*%TEAL%   Small Charm   %BLUE%*
ItemDisplay[(cm2) MAG !ID (ILVL<90) (FILTLVL<8)]: %DOT-9B%%BLUE%*%TEAL%   Large Charm   %BLUE%*
ItemDisplay[(cm3) MAG !ID (ILVL<90) (FILTLVL<8)]: %DOT-9B%%BLUE%*%TEAL%   Grand Charm   %BLUE%*

// 4) Filter levels below 8: show 90+ GCs with a special name
ItemDisplay[(cm1) MAG !ID (ILVL>89) (FILTLVL<8)]: %DOT-9B%%BLUE%*%BLUE%*%BLUE%*    %TEAL%Small Charm   %BLUE%*%BLUE%*%BLUE%*
ItemDisplay[(cm2) MAG !ID (ILVL>89) (FILTLVL<8)]: %DOT-9B%%BLUE%*%BLUE%*%BLUE%*    %TEAL%Large Charm    %BLUE%*%BLUE%*%BLUE%*
ItemDisplay[(cm3) MAG !ID (ILVL>89) (FILTLVL<8)]: %DOT-9B%%BLUE%*%BLUE%*%BLUE%*    %TEAL%Grand Charm    %BLUE%*%BLUE%*%BLUE%*

// 5) Default charm display (fallback / safety net)
ItemDisplay[(cm1 OR cm2 OR cm3) UNI !ID]: %PX-68%%NAME%

// Charm tooltip notes
ItemDisplay[cm2 UNI]: %NAME%{%TAN%Note%WHITE%: Cube with %GRAY%key %WHITE%to Destroy Into: %ORANGE%Hellfire Ashes}%CONTINUE%
