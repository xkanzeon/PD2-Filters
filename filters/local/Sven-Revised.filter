/~~~//formatting		
ItemDisplay[NMAG (WEAPON OR ARMOR) SUP !RW !misc_i !quest_i]:%BASENAME%{%NAME%}%CONTINUE%	
ItemDisplay[(NORM OR normquiver_i) !misc_i !quest_i]:¹%NAME%{%NAME%}%CONTINUE%
ItemDisplay[(EXC OR excquiver_i) !misc_i !quest_i]:²%NAME%{%NAME%}%CONTINUE%
ItemDisplay[(ELT OR eltquiver_i) !misc_i !quest_i]:³%NAME%{%NAME%}%CONTINUE%
\~~~
/~~~//coloring
ItemDisplay[UNI]:%GOLD%%NAME%{%NAME%}%CONTINUE%
ItemDisplay[SET]:%GREEN%%NAME%{%NAME%}%CONTINUE%
ItemDisplay[RARE !jew]:%YELLOW%%NAME%{%NAME%}%CONTINUE%	
ItemDisplay[RARE ID jew]:%YELLOW%%NAME%{%NAME%}%CONTINUE%			
ItemDisplay[MAG !jew]:%BLUE%%NAME%{%NAME%}%CONTINUE%
ItemDisplay[MAG ID jew]:%BLUE%%NAME%{%NAME%}%CONTINUE%		
ItemDisplay[CRAFT]:%ORANGE%%NAME%{%NAME%}%CONTINUE%	
ItemDisplay[!ZON SUP ETH NMAG !RW ED=20 AR=0]:%PURPLE%%NAME%{%NAME%}%CONTINUE%	//change this to only show up on good bases not all bases	
