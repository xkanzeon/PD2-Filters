//how to add tri res
//1 set the alias up
//2 add the alias tag to itemdisplay

//tri res labelling
//boots,amulet,helm = A
//gloves,ring,belt = B
Alias[TRI_RES_A1]:(CRES>24 AND LRES>24 AND FRES>24 AND PRES=0)
Alias[TRI_RES_A2]:(CRES>24 AND LRES>24 AND PRES>24 AND FRES=0)
Alias[TRI_RES_A3]:(CRES>24 AND FRES>24 AND PRES>24 AND LRES=0)
Alias[TRI_RES_A4]:(LRES>24 AND FRES>24 AND PRES>24 AND CRES=0)
Alias[TRI_RES_B1]:(CRES>19 AND LRES>19 AND FRES>19 AND PRES=0)
Alias[TRI_RES_B2]:(CRES>19 AND LRES>19 AND PRES>19 AND FRES=0)
Alias[TRI_RES_B3]:(CRES>19 AND FRES>19 AND PRES>19 AND LRES=0)
Alias[TRI_RES_B4]:(LRES>19 AND FRES>19 AND PRES>19 AND CRES=0)
//boots,amulet,helm = A
ItemDisplay[(BOOTS OR HELM OR amu) (MAG OR RARE OR CRAFT) TRI_RES_A1]:%NAME%{%CL%%BLUE%*%YELLOW%*%RED%*%PURPLE%Tri-Res%PURPLE%%BLUE%*%YELLOW%*%RED%*%NAME%}%CONTINUE%
