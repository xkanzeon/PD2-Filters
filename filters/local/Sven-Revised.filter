//OTHER SHOP HUNTING HIGHLIGHTS
//SHOPHUNT01 - HIGH ED
Alias[SHOPHUNT01]: ((WEAPON (EXC OR ELT) (EDAM>249)) OR (ARMOR (EDAM>149)) OR (WEAPON (EXC OR ELT) (EDAM>199 AND (SUFFIX=662 OR SUFFIX=898 OR SUFFIX=899))))
//SHOPHUNT02 - LOW ED
Alias[SHOPHUNT02]: ((STAT36>14 AND EDAM~1-150) OR (STAT36>9 AND EDAM~100-150))
//SHOPHUNT03 - TELEPORT CHARGES
Alias[SHOPHUNT03]: (CHSK54>0)
//SHOPHUNT04 - LOW RES CTC
Alias[SHOPHUNT04]: (SUFFIX=909 OR SUFFIX=912)
//SHOPHUNT05 - AMP DMG CTC
Alias[SHOPHUNT05]: ((SUFFIX=899 OR SUFFIX=906) OR (WEAPON (EXC OR ELT) (EDAM>199 AND (SUFFIX=662 OR SUFFIX=898 OR SUFFIX=899))))
//SHOPHUNT06 - LOW RES CHARGES
Alias[SHOPHUNT06]: (SUFFIX=594 OR SUFFIX=595)
//SHOPHUNT07 - LIFE TAP CHARGES
Alias[SHOPHUNT07]: (SUFFIX=578 OR SUFFIX=579)
//SHOPHUNT08 - HIGH PDR
Alias[SHOPHUNT08]: (STAT36>14)
//SHOPHUNT09 - LOW PDR
Alias[SHOPHUNT09]: ((STAT36~1-14 AND EDAM>149) OR (STAT36~10-14 AND EDAM>99) OR (STAT36~10-14 AND RES>9))
//SHOPHUNT10 - ALL RES
Alias[SHOPHUNT10]: ((RES>19) OR (STAT36~10-14 AND RES>9))
//SHOPHUNT11 - PDR BELT
Alias[SHOPHUNT11]: (BELT STAT36>4)
//SHOPHUNT12 - FIRE RES GLOVES OR BELT
Alias[SHOPHUNT12]: ((GLOVES OR BELT) MAG ((FRES>14 DIFF=0) OR (FRES>24 DIFF>0)))
//SHOPHUNT13 - FIRE RES BOOTS
Alias[SHOPHUNT13]: (BOOTS MAG ((FRES>14 DIFF=0) OR (FRES>24 DIFF=1) OR (FRES>34 DIFF=2)))
//SHOPHUNT14 - COLD RES GLOVES OR BELT
Alias[SHOPHUNT14]: ((GLOVES OR BELT) MAG ((CRES>14 DIFF=0) OR (CRES>24 DIFF>0)))
//SHOPHUNT15 - COLD RES BOOTS
Alias[SHOPHUNT15]: (BOOTS MAG ((CRES>14 DIFF=0) OR (CRES>24 DIFF=1) OR (CRES>34 DIFF=2)))
//SHOPHUNT16 - LIGHT RES GLOVES OR BELT
Alias[SHOPHUNT16]: ((GLOVES OR BELT) MAG ((LRES>14 DIFF=0) OR (LRES>24 DIFF>0)))
//SHOPHUNT17 - LIGHT RES BOOTS
Alias[SHOPHUNT17]: (BOOTS MAG ((LRES>14 DIFF=0) OR (LRES>24 DIFF=1) OR (LRES>34 DIFF=2)))
//SHOPHUNT18 - POISON RES GLOVES OR BELT
Alias[SHOPHUNT18]: ((GLOVES OR BELT) MAG ((PRES>14 DIFF=0) OR (PRES>24 DIFF>0)))
//SHOPHUNT19 - POISON RES BOOTS
Alias[SHOPHUNT19]: (BOOTS MAG ((PRES>14 DIFF=0) OR (PRES>24 DIFF=1) OR (PRES>34 DIFF=2)))
