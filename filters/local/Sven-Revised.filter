Alias[PD2LOWUNIETH1]: ((am5) UNI ETH !ID)
//Lower Value PD2 UNIQUES
Alias[PD2LOWUNI1]: ((ba6 OR dr2 OR ne6 OR ulb OR 7cm OR 7fb OR aqv2 OR cqv2 OR 7st OR 9b8) UNI !ID)
//PD2 Uniques worth notifying
Alias[PD2NOTIFYUNI1]: ((9ar OR ob6 OR am5 OR pa3 OR ba7 OR ob7) UNI !ID)
//LOD UNIQUES
//GG UNIQUES only when ETH
Alias[LODGGUNIETH1]: ((9gm OR 7gm OR 7s8 OR 7p7 OR 7wa OR 7wh OR uul) UNI ETH !ID)
//GG UNIQUES
Alias[LODGGUNI1]: ((rin OR amu OR 6ws OR uar OR ulc OR urn OR uap OR ci3 OR xtb OR uit OR 6lw OR 7gw OR obf OR uhm OR 7gd) UNI !ID)
//OK UNIQUES only when ETH - Armors
Alias[LODOKUNIETH1]: ((xpl) UNI ETH !ID)
//OK UNIQUES only when ETH - Weapons
Alias[LODOKUNIETH2]: ((7gi OR 7m7 OR 7gl OR 7b8 OR 7bk OR 7ha OR 7b7 OR 7sr OR 9la OR 8ls OR 7ga OR amd) UNI ETH !ID)
//belts
Alias[LODOKUNI1]: ((ztb OR zlb OR zvb OR zhb OR umc OR uvc) UNI !ID)
//armors
Alias[LODOKUNI2]: ((xea OR uui OR xhn OR xlt OR upl OR uld OR utu OR uul) UNI !ID)
//gloves
Alias[LODOKUNI3]: ((uvg OR uhg OR umg) UNI !ID)
//helmets
Alias[LODOKUNI4]: ((xh9 OR usk OR ci2 OR baa OR bac OR dra OR dre OR uh9 OR xhm OR drd OR bae OR ulm) UNI !ID)
//boots
Alias[LODOKUNI5]: ((lbt OR xhb OR uhb OR xvb) UNI !ID)
//shields
Alias[LODOKUNI6]: ((nee OR pa9 OR nea OR uts OR uow OR xow OR pae OR nef OR pac) UNI !ID)
//weapons
Alias[LODOKUNI7]: ((7ts OR 7s8 OR 9bw OR 7wc OR 7bw OR 7ws OR 7fl OR 7cr OR 7gm OR oba OR ama OR obc OR amf OR 7wh OR 7p7 OR 7wa OR 7lw OR 8mx) UNI !ID)
//OK/Lower Value UNIQUES only when ETH
Alias[LODLOWUNIETH1]: ((mau OR 9st OR uvb OR 9m9) UNI ETH !ID)
//OK/Lower Value UNIQUES
Alias[LODLOWUNI1]: ((7pa OR 7bt OR ltp OR xcl OR 9tw OR xtp OR xth OR 7kr OR xpl OR xld OR 7b7 OR 8hx OR 7cs OR xmb OR tbt OR amb OR 7sc OR 7ha OR 7ls OR 7bl OR 6hx OR uml OR upk OR 7gl OR 9gm OR 7br OR ush OR 8ls OR bad OR 6sw OR 8cb OR 8ws OR tgl OR umb OR 7mp OR aar OR 9ls OR 7gi OR 7wb OR 7ga OR amd OR 8rx OR xtg OR xhg OR xsh OR 7dg) UNI !ID)
//Uniques worth notifying
//Armors
Alias[LODNOTIFYUNI1]: ((brs OR fld OR xkp OR xul OR xlm OR drb OR 9sp OR mbt OR rng OR xng OR xui OR spl OR xmg OR xsk OR xml OR xlb OR xap OR xrs OR gth OR (BELT !(vbl OR hbl)) OR skp OR xhl OR xrn OR vbt OR uvb OR lgl OR vgl OR mgl OR hgl OR xlg OR xvg OR xts OR xrg OR xar) UNI !ID)
//Weapons
Alias[LODNOTIFYUNI2]: (((8lb OR 92h OR 8s8 OR 9wc OR 92h OR 6rx OR 9gw OR 7m7 OR 9cl OR mau OR 7sr OR 9ba OR 72a OR 7o7 OR 9yw OR 9fc OR 9kr OR 6l7 OR dgr OR 9ma OR 9wh OR 9ws OR 6cs OR 7gs OR 9sb OR 9bs OR 9tr OR 9la OR 9s8 OR 9m9) OR (ELT (THROWING OR JAV)) OR 7sp) UNI !ID)
//SET PARTS
//OK SET parts when ETH
Alias[OKSETETH1]: ((7fb OR 7gd OR 7ls OR 7m7 OR 7qr) SET ETH !ID)
//OK SET parts
Alias[OKSET1]: ((uar OR ci3 OR 7qr OR uth OR paf OR urn OR 7ws) SET !ID)
//OK/Lower Value SET parts
Alias[LOWSET1]: ((amu OR rin) SET !ID)
//Sets worth notifying
Alias[NOTIFYSET1]: (((ARMOR OR WEAPON OR QUIVER) (EXC OR ELT OR ci0 OR ba5 OR lbt) !(9vo OR xcl OR xrn)) SET !ID)
//NMAG ITEMS WITH ED TO SHOW EXACT ED VALUES 
//Armors
Alias[EDARMOR]: ((((CHEST OR (HELM !(BAR OR DRU)) OR (SHIELD !(DIN OR NEC))) ELT) OR (DIN (EXC OR ELT) (RES>19 OR AR>100)) OR (gth OR ful OR aar) OR (xng OR xcl OR xhn OR xrs OR xpl OR xlt OR xld OR xtp) OR ci3 OR xsh OR xpk OR xhm OR (RW ARMOR)) !SOCK=1 !INF SUP NMAG ED>4)
//Weapons
Alias[EDWEAPON]: ((((WEAPON !SIN !SOR !WAND !SCEPTER !STAFF !(clb OR 9cl OR 7cl OR spc OR 9sp OR 7sp) !DAGGER) ELT) OR 8rx OR (RW WEAPON)) !SOCK=1 !INF SUP NMAG ED>4)
