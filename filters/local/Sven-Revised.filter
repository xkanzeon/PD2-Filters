//PD2 UBERS DCLONE/DUNGEON/RATHMA/LUCION BOSSES UNIQUES
Alias[PD2UBERUNI1]: (((uh9 MAPID=137) OR uth OR utb OR 7bs OR 7qr) UNI !ID)
Alias[PD2UBERUNI2]: ((rar OR rbe OR ram) UNI !ID)
