/~~~//kryzard alias
//DEFINE ALIASES
//Throwing Potions
Alias[THROWPOTS]: (opm OR gpm OR opl OR ops OR gps OR gpl OR tpfs OR tpgs OR tpcs OR tpls OR tpfm OR tpgm OR tpcm OR tplm OR tpfl OR tpgl OR tpcl OR tpll)
//Vengance Charms Prefixes
Alias[HIGHVENGPFX]: (PREFIX=617 OR PREFIX=621 OR PREFIX=625 OR PREFIX=629 OR PREFIX=633 OR PREFIX=637 OR PREFIX=641 OR PREFIX=645 OR PREFIX=649)
Alias[MIDVENGPFX]: (PREFIX=616 OR PREFIX=620 OR PREFIX=624 OR PREFIX=628 OR PREFIX=632 OR PREFIX=636 OR PREFIX=640 OR PREFIX=644 OR PREFIX=648)
Alias[LOWVENGPFX]: (PREFIX=615 OR PREFIX=619 OR PREFIX=623 OR PREFIX=627 OR PREFIX=631 OR PREFIX=635 OR PREFIX=639 OR PREFIX=643 OR PREFIX=647)
//Vengance Charms Suffixes
Alias[HIGHVENGSFX]: (SUFFIX=697 OR SUFFIX=701 OR SUFFIX=705 OR SUFFIX=709 OR SUFFIX=713 OR SUFFIX=717 OR SUFFIX=721 OR SUFFIX=725 OR SUFFIX=729)
Alias[MIDVENGSFX]: (SUFFIX=696 OR SUFFIX=700 OR SUFFIX=704 OR SUFFIX=708 OR SUFFIX=712 OR SUFFIX=716 OR SUFFIX=720 OR SUFFIX=724 OR SUFFIX=728)
Alias[LOWVENGSFX]: (SUFFIX=695 OR SUFFIX=699 OR SUFFIX=703 OR SUFFIX=707 OR SUFFIX=711 OR SUFFIX=715 OR SUFFIX=719 OR SUFFIX=723 OR SUFFIX=727)
//Towns
Alias[TOWN]: (MAPID=1 OR MAPID=40 OR MAPID=75 OR MAPID=103 OR MAPID=109)
//Known Maps
Alias[KNOWNMAPS]: (t11 OR t12 OR t13 OR t14 OR t15 OR t16 OR t17 OR t21 OR t22 OR t23 OR t24 OR t25 OR t26 OR t27 OR t28 OR t31 OR t32 OR t33 OR t34 OR t35 OR t36 OR t37 OR t38 OR t39 OR t3a OR t41 OR t42 OR t43 OR t44 OR t51 OR t52 OR t53 OR t54 OR t55 OR t56 OR t57 OR t58 OR t3b)
