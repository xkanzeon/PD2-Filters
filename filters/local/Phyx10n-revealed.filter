#\\\
#///Styling
//Rarity Colors
ItemDisplay[NMAG (ARMOR OR WEAPON OR QUIVER)]:%WHITE%%SHOW%%CONTINUE%
ItemDisplay[MAG]:%BLUE%%SHOW%%CONTINUE%
ItemDisplay[RARE]:%YELLOW%%SHOW%%CONTINUE%
ItemDisplay[CRAFT]:%ORANGE%%SHOW%%CONTINUE%
ItemDisplay[SET]:%GREEN%%SHOW%%CONTINUE%
ItemDisplay[UNI OR QUEST]:%GOLD%%SHOW%%CONTINUE%
//Modifiers
ItemDisplay[ETH]:%GRAY%eth %SHOW%%CONTINUE%
ItemDisplay[STAT360=32 SOCK>0]:%SHOW% %TAN%(%WHITE%%SOCKETS%%TAN%)%RED%*%CONTINUE%
ItemDisplay[!STAT360=32 SOCK>0]:%SHOW% %TAN%(%WHITE%%SOCKETS%%TAN%)%CONTINUE%
ItemDisplay[!WEAPON !QUIVER !tbk !ibk QTY>1]:%SHOW% %TAN%x %WHITE%%QTY%%CONTINUE%
//Maps
ItemDisplay[MAPTIER=1]:%ORANGE%T1 %WHITE%%SHOW%%CONTINUE%
ItemDisplay[(MAPTIER=2 OR t53)]:%ORANGE%T2 %WHITE%%SHOW%%CONTINUE%
ItemDisplay[(MAPTIER=3 OR t51 OR t52 OR t54 OR t55 OR t56)]:%ORANGE%T3 %WHITE%%SHOW%%CONTINUE%
ItemDisplay[MAPTIER=4]:%ORANGE%T4 %WHITE%%SHOW%%CONTINUE%
//Sell
ItemDisplay[FILTLVL<3 (GROUND OR INVENTORY) ID !SET !UNI !RW (!MISC OR QUIVER OR JEWELRY) ((DIFF=0 SELLPRICE=25000) OR (DIFF=1 SELLPRICE=30000) OR SELLPRICE=35000)]:%SHOW% %YELLOW%$%CONTINUE%
#\\\
#///Descriptions
//Stats
ItemDisplay[!GROUND WEAPON]:%NAME%{%WHITE%Speed: %WPNSPD% Range: %RANGE%%CL%%NAME%}%CONTINUE%
//Max Block Dex
ItemDisplay[EQUIPPED PALADIN SHIELD]:%NAME% {%WHITE%Max Block Dex: $f(CEIL(CHARSTAT12*150/(CHARSTAT20+30)+15))%CL%%NAME%}%CONTINUE%
ItemDisplay[EQUIPPED (AMAZON OR ASSASSIN OR BARBARIAN) SHIELD]:%NAME% {%WHITE%Max Block Dex: $f(CEIL(CHARSTAT12*150/(CHARSTAT20+25)+15))%CL%%NAME%}%CONTINUE%
ItemDisplay[EQUIPPED (DRUID OR NECROMANCER OR SORCERESS) SHIELD]:%NAME% {%WHITE%Max Block Dex: $f(CEIL(CHARSTAT12*150/(CHARSTAT20+20)+15))%CL%%NAME%}%CONTINUE%
//Affix Level
ItemDisplay[!GROUND ID ((RARE jew) OR (MAG cm3 ILVL>90))]:%NAME%{%WHITE%Reroll Affix Level: %REROLLALVL%%CL%%NAME%}%CONTINUE%
//Socket Recipes
ItemDisplay[!EQUIPPED NMAG !INF (HELM OR CIRC OR CHEST OR SHIELD OR QUIVER OR WEAPON) !JUNK SOCK=0]:%NAME%{%GOLD%Cube for Socket Recipe%CL%%NAME%}%CONTINUE%
ItemDisplay[!GROUND NMAG !INF (HELM OR CIRC) SOCK=0]:%NAME%{%WHITE%Socket: %ORANGE%Ral %WHITE%+ %ORANGE%Thul %WHITE%+ %BLUE%O%CL%%NAME%}%CONTINUE%
ItemDisplay[!GROUND NMAG !INF CHEST SOCK=0]:%NAME%{%WHITE%Socket: %ORANGE%Tal %WHITE%+ %ORANGE%Thul %WHITE%+ %YELLOW%O%CL%%NAME%}%CONTINUE%
ItemDisplay[!GROUND NMAG !INF (SHIELD OR QUIVER) SOCK=0]:%NAME%{%WHITE%Socket: %ORANGE%Tal %WHITE%+ %ORANGE%Amn %WHITE%+ %RED%O%CL%%NAME%}%CONTINUE%
ItemDisplay[!GROUND NMAG !INF WEAPON !JUNK SOCK=0]:%NAME%{%WHITE%Socket: %ORANGE%Ral %WHITE%+ %ORANGE%Amn %WHITE%+ %PURPLE%O%CL%%NAME%}%CONTINUE%
//Max Sockets
ItemDisplay[!EQUIPPED ID (ARMOR OR WEAPON OR QUIVER) SOCK=0 MAXSOCKETS>0]:%NAME%{%WHITE%Max Sockets: $f(MIN(MAXSOCKETS,IF(AND(!NMAG,ONEHAND),4,6),IF(AND(!NMAG,!WEAPON),3,6),IF(STAT360>0,IF(TWOHAND,4,2),6)))%CL%%NAME%}%CONTINUE%
//Upgrade Recipes
ItemDisplay[!EQUIPPED !CUBE ID !NMAG !MAG !ELT (ARMOR OR WEAPON OR QUIVER)]:%NAME%{%GOLD%Cube for Upgrade Recipe%CL%%NAME%}%CONTINUE%
ItemDisplay[CUBE ID (RARE OR CRAFT) NORM (ARMOR OR QUIVER)]:%NAME%{%WHITE%Upgrade: %ORANGE%Ral %WHITE%+ %ORANGE%Thul %WHITE%+ %PURPLE%O%CL%%NAME%}%CONTINUE%
ItemDisplay[CUBE ID (RARE OR CRAFT) EXC (ARMOR OR QUIVER)]:%NAME%{%WHITE%Upgrade: %ORANGE%Ko %WHITE%+ %ORANGE%Pul %WHITE%+ %PURPLE%O%CL%%NAME%}%CONTINUE%
ItemDisplay[CUBE ID (RARE OR CRAFT) NORM WEAPON]:%NAME%{%WHITE%Upgrade: %ORANGE%Ort %WHITE%+ %ORANGE%Amn %WHITE%+ %BLUE%O%CL%%NAME%}%CONTINUE%
ItemDisplay[CUBE ID (RARE OR CRAFT) EXC WEAPON]:%NAME%{%WHITE%Upgrade: %ORANGE%Fal %WHITE%+ %ORANGE%Um %WHITE%+ %BLUE%O%CL%%NAME%}%CONTINUE%
ItemDisplay[CUBE ID (SET OR UNI) NORM (ARMOR OR QUIVER)]:%NAME%{%WHITE%Upgrade: %ORANGE%Tal %WHITE%+ %ORANGE%Shael %WHITE%+ O%CL%%NAME%}%CONTINUE%
ItemDisplay[CUBE ID (SET OR UNI) EXC (ARMOR OR QUIVER)]:%NAME%{%WHITE%Upgrade: %ORANGE%Ko %WHITE%+ %ORANGE%Lem %WHITE%+ O%CL%%NAME%}%CONTINUE%
ItemDisplay[CUBE ID (SET OR UNI) NORM WEAPON]:%NAME%{%WHITE%Upgrade: %ORANGE%Ral %WHITE%+ %ORANGE%Sol %WHITE%+ %GREEN%O%CL%%NAME%}%CONTINUE%
ItemDisplay[CUBE ID (SET OR UNI) EXC WEAPON]:%NAME%{%WHITE%Upgrade: %ORANGE%Lum %WHITE%+ %ORANGE%Pul %WHITE%+ %GREEN%O%CL%%NAME%}%CONTINUE%
//Upgrade Requirements
ItemDisplay[CUBE ID !NMAG !MAG !ELT $f(OR(UPSTR>0,UPDEX>0))]:%NAME%{%GRAY%)%CL%%NAME%}%CONTINUE%
ItemDisplay[CUBE ID !NMAG !MAG !ELT $f(UPDEX>0) !$f(UPDEX>CHARSTAT2-STAT2)]:%NAME%{%GRAY%, Dex %UPDEX%%NAME%}%CONTINUE%
ItemDisplay[CUBE ID !NMAG !MAG !ELT $f(UPDEX>0) $f(UPDEX>CHARSTAT2-STAT2)]:%NAME%{%GRAY%, %RED%Dex %UPDEX%%NAME%}%CONTINUE%
ItemDisplay[CUBE ID !NMAG !MAG !ELT $f(UPSTR>0) !$f(UPSTR>CHARSTAT0-STAT0)]:%NAME%{%GRAY% Str %UPSTR%%NAME%}%CONTINUE%
ItemDisplay[CUBE ID !NMAG !MAG !ELT $f(UPSTR>0) $f(UPSTR>CHARSTAT0-STAT0)]:%NAME%{%RED% Str %UPSTR%%NAME%}%CONTINUE%
ItemDisplay[CUBE ID !NMAG !MAG !ELT $f(OR(UPSTR>0,UPDEX>0))]:%NAME%{%GRAY%(Requires:%NAME%}%CONTINUE%
