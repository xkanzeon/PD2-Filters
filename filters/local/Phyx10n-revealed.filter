//Items/Areas
Alias[TOWN]:(MAPID=1 OR MAPID=40 OR MAPID=75 OR MAPID=103 OR MAPID=109)
Alias[QUEST]:(bks OR bkd OR hdm OR tr1 OR ass OR box OR msf OR vip OR hst OR j34 OR g34 OR xyz OR g33 OR bbb OR qbr OR qey OR qhr OR qf1 OR qf2 OR mss OR hfh OR ice OR tr2 OR leg)
Alias[JUNK]:(hp1 OR mp1 OR hp2 OR mp2 OR hp3 OR mp3 OR hp4 OR mp4 OR hp5 OR mp5 OR rvs OR yps OR wms OR vps OR tsc OR isc OR key OR tpfs OR tpfm OR tpfl OR tpgs OR tpgm OR tpgl OR tpcs OR tpcm OR tpcl OR tpls OR tplm OR tpll OR GOLD<10000 OR (NMAG (INF OR SOCK=1) (ARMOR OR WEAPON OR QUIVER)))
Alias[STAFFMOD]:(BAR OR DRU OR NEC OR SIN OR SOR OR CLUB OR DAGGER OR SCEPTER OR STAFF OR WAND)
Alias[MELEE]:(WEAPON !CASTER)
Alias[CASTER]:(SOR OR STAFF OR WAND)
//Formulae
Alias[NORM_XP]:(1-MIN(MAX(ABS(%LVLDIFF%)-5,0)*0.19,0.95))
Alias[ELITE_XP]:(1-MIN(MAX(ABS(%ELITEDIFF%)-5,0)*0.19,0.95))
Alias[LVLDIFF]:(IF(MAPTIER==4,92,IF(OR(MAPTIER==3,MAPTIER==5),89,IF(MAPTIER==2,88,87)))+STAT374-CHARSTAT12)
Alias[ELITEDIFF]:(IF(MAPTIER==4,92,IF(OR(MAPTIER==3,MAPTIER==5),89,IF(MAPTIER==2,88,87)))+3+STAT374-CHARSTAT12)
Alias[MAGICFIND]:(CHARSTAT80*250/(CHARSTAT80+250))
Alias[MAPMAGICFIND]:((STAT370+CHARSTAT80)*250/((STAT370+CHARSTAT80)+250))
