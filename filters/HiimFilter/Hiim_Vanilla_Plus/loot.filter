//-----------------------------------------------------------------------------------

// ------------------------------------------------------------------------------
// Tool-tip Pts AMU / RING / JEWEL — raw weighted score as "NNN%" (centipoints)
// ------------------------------------------------------------------------------
// Color: ORANGE normally, PURPLE at 6Pt+ (rings/amulets) or 4Pt+ (jewels).
// Divisors live in 06-hiim_pts_formula: PTS_RING_DIV / PTS_AMU_DIV / PTS_MELEEJEW_DIV / PTS_CASTERJEW_DIV / PTS_LLDJEW_DIV
// ------------------------------------------------------------------------------

// PVM Melee Ring
ItemDisplay[rin !UNI !SET ID MINDMG+MAXDMG>9 $f(ROUND(PTSRING_MELEE*100/PTS_RING_DIV/100))~3-5]: %CONTINUE%%NAME% %ORANGE%$f(ROUND(%PTSRING_MELEE%*100/%PTS_RING_DIV%)/100)pt{%ORANGE%$f(ROUND(%PTSRING_MELEE%*100/%PTS_RING_DIV%)/100) pt PVM Melee Ring%CL%%NAME%}
ItemDisplay[rin !UNI !SET ID MINDMG+MAXDMG>9 $f(ROUND(PTSRING_MELEE*100/PTS_RING_DIV/100))>5]: %CONTINUE%%NAME% %PURPLE%$f(ROUND(%PTSRING_MELEE%*100/%PTS_RING_DIV%)/100)pt{%PURPLE%$f(ROUND(%PTSRING_MELEE%*100/%PTS_RING_DIV%)/100) pt PVM Melee Ring%CL%%NAME%}

// PVM Caster Ring (STAT86 and STAT138 weights live in the alias — each value of 2 = 1Pt)
ItemDisplay[rin !UNI !SET ID FCR>0 $f(ROUND(PTSRING_CASTER*100/PTS_RING_DIV/100))~3-5]: %CONTINUE%%NAME% %ORANGE%$f(ROUND(%PTSRING_CASTER%*100/%PTS_RING_DIV%)/100)pt{%ORANGE%$f(ROUND(%PTSRING_CASTER%*100/%PTS_RING_DIV%)/100) pt PVM Caster Ring%CL%%NAME%}
