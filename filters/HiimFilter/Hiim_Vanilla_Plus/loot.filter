// Alias for item ground annotations Vanilla++
//-----------------------------------------------------------------------------------

// General item
Alias[GEN_ITEM]: %NAME%

// General item Alt
Alias[GEN_ALT]: %PURPLE%O %NAME% %PURPLE%O

// Token parts
Alias[TOKEN_PARTS]: %ORANGE%> %NAME% %ORANGE%<

// Uber Keys
Alias[UBER_KEYS]: %RED%> %NAME% %RED%<

// Boss Mat Item
Alias[BOSS_MAT]: %YELLOW%<> %NAME% %YELLOW%<>

// Boss Mat Item Alt
Alias[BOSS_ALT]: %YELLOW%<> %NAME% %YELLOW%<>

// Boss Entry Item
Alias[BOSS_ENTRY]: %RED%* * %NAME% %RED%* *

// Rare General Item
Alias[GEN_RARE]: %ORANGE%<> %NAME% %ORANGE%<>

// Rarer General Item
Alias[GEN_TOP_RARE]: %DARK_GREEN%<> %NAME% %DARK_GREEN%<>

// GG General Item Drop
Alias[GEN_GG_ITEM]: %PURPLE%<> %NAME% %PURPLE%<>

// Rare GG Item Drop
Alias[RARE_GG_ITEM]: %PURPLE%<%GREEN%!%PURPLE%> %PURPLE%<%GREEN%!%PURPLE%> %PURPLE%<%GREEN%!%PURPLE%> %PURPLE%<%GREEN%!%PURPLE%> %NAME% %PURPLE%<%GREEN%!%PURPLE%> %PURPLE%<%GREEN%!%PURPLE%> %PURPLE%<%GREEN%!%PURPLE%> %PURPLE%<%GREEN%!%PURPLE%>

// Unlimited Use items
