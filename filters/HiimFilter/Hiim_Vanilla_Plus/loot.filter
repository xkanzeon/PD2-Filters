// RES value on PALADIN shields
ItemDisplay[!INF !RW NMAG RES>0]: %GREEN%[%RES%r] %NAME%{%NAME%}%CONTINUE%
//ItemDisplay[!INF !RW NMAG RES>29]: %GREEN%* * %NAME% %GREEN%* *{%NAME%}%CONTINUE%

// ITEM TAGS - DEF on Chest
ItemDisplay[CHEST !INF !RW NMAG DEF>400]: %TAN%[%DEF% Def] %NAME%{%NAME%}%CONTINUE%
ItemDisplay[CHEST !INF !RW NMAG DEF>799]: %DOT-D6%%NAME%{%NAME%}%CONTINUE%

// ITEM TAGS - EDEF
ItemDisplay[!INF !RW NMAG EDEF>0]: %BLUE%[%EDEF%%] %NAME%{%NAME%}%CONTINUE%
ItemDisplay[!INF !RW NMAG EDEF=20]: %BLUE%* * %NAME% %BLUE%* *{%NAME%}%CONTINUE%

// ITEM TAGS - EDAM
ItemDisplay[!INF !RW NMAG EDAM>0]: %RED%[%EDAM%%] %NAME%{%NAME%}%CONTINUE%
ItemDisplay[!INF !RW NMAG EDAM=20 !DIN]: %RED%* * %NAME% %RED%* *{%NAME%}%CONTINUE%

// ITEM TAGS - LARZUK FOR SOCKETS
ItemDisplay[NMAG SOCK=0 MAXSOCKETS>0 (ARMOR OR WEAPON OR QUIVER)]:%NAME%{%TAN%Larzuk for $f(MIN(MAXSOCKETS,IF(AND(!NMAG,ONEHAND),4,6),IF(AND(!NMAG,!WEAPON),3,6),IF(STAT360>0,IF(TWOHAND,4,2),6))) sockets%CL%%NAME%}%CONTINUE%

