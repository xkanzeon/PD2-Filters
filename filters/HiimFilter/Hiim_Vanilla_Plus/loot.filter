// ITEM TAGS - Specific Mods
ItemDisplay[(RARE OR CRAFT) FOOLS]: %NAME% %PURPLE%FOOLS%CONTINUE%

// Amplify Damage on Striking
ItemDisplay[(MAG OR CRAFT OR RARE) WEAPON SUFFIX=662]: %NAME% %ORANGE%[amp]%CONTINUE%%DOT-0B% // Low amp
ItemDisplay[(MAG OR CRAFT OR RARE) WEAPON SUFFIX=898]: %NAME% %ORANGE%[Amp]%CONTINUE%%DOT-0B% // mid amp
ItemDisplay[(MAG OR CRAFT OR RARE) WEAPON SUFFIX=899]: %NAME% %ORANGE%[AMP]%CONTINUE%%DOT-0B% // High amp

// Amplify Damage on Casting
ItemDisplay[(MAG OR CRAFT OR RARE) WEAPON SUFFIX=904]: %NAME% %ORANGE%[amp]%CONTINUE%%DOT-0B% // Low amp
ItemDisplay[(MAG OR CRAFT OR RARE) WEAPON SUFFIX=905]: %NAME% %ORANGE%[Amp]%CONTINUE%%DOT-0B% // mid amp
ItemDisplay[(MAG OR CRAFT OR RARE) WEAPON SUFFIX=906]: %NAME% %ORANGE%[AMP]%CONTINUE%%DOT-0B% // High amp

// Lower Res on Striking 
ItemDisplay[(MAG OR CRAFT OR RARE) WEAPON SUFFIX=907]: %NAME% %PURPLE%[lr]%CONTINUE%%DOT-0B% // Low lr
ItemDisplay[(MAG OR CRAFT OR RARE) WEAPON SUFFIX=908]: %NAME% %PURPLE%[Lr]%CONTINUE%%DOT-0B% // mid lr
ItemDisplay[(MAG OR CRAFT OR RARE) WEAPON SUFFIX=909]: %NAME% %PURPLE%[LR]%CONTINUE%%DOT-0B% // High lr

// Lower Res on Casting
ItemDisplay[(MAG OR CRAFT OR RARE) WEAPON SUFFIX=910]: %NAME% %PURPLE%[lr]%CONTINUE%%DOT-0B% // Low lr
ItemDisplay[(MAG OR CRAFT OR RARE) WEAPON SUFFIX=911]: %NAME% %PURPLE%[Lr]%CONTINUE%%DOT-0B% // mid lr
ItemDisplay[(MAG OR CRAFT OR RARE) WEAPON SUFFIX=912]: %NAME% %PURPLE%[LR]%CONTINUE%%DOT-0B% // High lr

//DEF on Chest
ItemDisplay[CHEST (MAG OR CRAFT OR RARE) ID DEF>400]: %NAME% %TAN%%DEF% Def{%NAME%}%CONTINUE%


//ED
ItemDisplay[WEAPON EDAM>49 EDAM<200]: %NAME%%WHITE%%CONTINUE%
ItemDisplay[WEAPON EDAM>199 EDAM<300]: %DOT-0B%%NAME%%BLUE%%CONTINUE%
ItemDisplay[WEAPON EDAM>299 EDAM<400]: %DOT-0B%%NAME%%ORANGE%%CONTINUE%
ItemDisplay[WEAPON EDAM>399]: %DOT-0B%%NAME%%PURPLE%%CONTINUE%
ItemDisplay[WEAPON EDAM>49]: %NAME% %EDAM%% ED%CONTINUE%

// ITEM TAGS - LLD UNI - Uniqes and sets to look out for or weapon rares
ItemDisplay[WEAPON !UNI (EDAM>149 OR SUFFIX=662 OR SUFFIX=898) LVLREQ<31]: %NAME% %TEAL%[LLD]%CONTINUE%
ItemDisplay[WEAPON !UNI (SUFFIX=907 OR SUFFIX=908 OR SUFFIX=910 OR SUFFIX=911) LVLREQ<31]: %NAME% %TEAL%[LLD]%CONTINUE%
ItemDisplay[UNI ID (stu OR gth OR aar OR xui OR vgl OR xap OR kit OR wax OR cbw OR mau OR gma OR wst OR flb OR gsd OR tbt OR zlb OR dr2 OR tgl OR fld OR am5) STAT360=0]: %NAME% %TEAL%[LLD]%CONTINUE%
ItemDisplay[SET ID (bwn OR vbt OR lbt OR lbl OR lgl) STAT360=0]: %NAME% %TEAL%[LLD]%CONTINUE%
ItemDisplay[SET ID amu (STAT360=0 AND STAT89=3)]: %NAME% %TEAL%[LLD]%CONTINUE%
ItemDisplay[SET ID rin (STAT360=0 AND STAT74=6)]: %NAME% %TEAL%[LLD]%CONTINUE%

//Half freeze duration when no CBF
ItemDisplay[STAT118>0 !EQUIPPED CHARSTAT118=1 CHARSTAT153=0]: %NAME% {%TAN%Equip to Gain: %BLUE%Cannot Be Frozen%CL%%NAME%}%CONTINUE%
ItemDisplay[STAT118>0 EQUIPPED CHARSTAT118<2 CHARSTAT153=0]: %NAME% {%TAN%%CHARSTAT118% of 2 Items for %GRAY%Cannot Be Frozen%CL%%NAME%}%CONTINUE%
ItemDisplay[STAT118>0 EQUIPPED CHARSTAT118>1 CHARSTAT153=0]: %NAME% {%TAN%%CHARSTAT118% of 2 Items for %BLUE%Cannot Be Frozen%CL%%NAME%}%CONTINUE%

