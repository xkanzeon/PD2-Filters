//-----------------------------------------------------------------------------------
// HiimFilter - PD2 Filter
//-----------------------------------------------------------------------------------

//-----------------------------------------------------------------------------------
// FILTER CONFIG
//-----------------------------------------------------------------------------------
// Filter Levels (0 = No Filter)
ItemDisplayFilterName[]: Base
ItemDisplayFilterName[]: Semi-Strict
ItemDisplayFilterName[]: Strict
ItemDisplayFilterName[]: Strict + No HP/MP
ItemDisplayFilterName[]: Stricter
ItemDisplayFilterName[]: Stricter + No HP/MP
ItemDisplayFilterName[]: Extremely Strict
ItemDisplayFilterName[]: High roller
ItemDisplayFilterName[]: 3 Minute Mapper & Rejuvs
ItemDisplayFilterName[]: 3 Minute Mapper
ItemDisplayFilterName[]: No Items Out of Town
//-----------------------------------------------------------------------------------

//-----------------------------------------------------------------------------------
// SHOW VERSION AND LEVEL DETAILS ON CUBE/KEYS
//-----------------------------------------------------------------------------------
ItemDisplay[box]: %NAME%{Send Feedback via PD2 Discord #lootfilter%CL%Last updated April 23rd%CL%Season 13 - build 51%CL%HiimFilter - Vanilla+ -}%CONTINUE%
ItemDisplay[box FILTLVL=0]: %NAME%{%NAME% OFF}%CONTINUE%
ItemDisplay[box FILTLVL=1]: %NAME%{%NAME% Base (1)}%CONTINUE%
ItemDisplay[box FILTLVL=2]: %NAME%{%NAME% Semi-Strict (2)}%CONTINUE%
ItemDisplay[box FILTLVL=3]: %NAME%{%NAME% Strict (3)}%CONTINUE%
ItemDisplay[box FILTLVL=4]: %NAME%{%NAME% Strict & No HP/MP (4)}%CONTINUE%
ItemDisplay[box FILTLVL=5]: %NAME%{%NAME% Stricter (5)}%CONTINUE%
ItemDisplay[box FILTLVL=6]: %NAME%{%NAME% Stricter & No HP/MP (6)}%CONTINUE%
ItemDisplay[box FILTLVL=7]: %NAME%{%NAME% Extremely Strict (7)}%CONTINUE%
ItemDisplay[box FILTLVL=8]: %NAME%{%NAME% High roller (8)}%CONTINUE%
ItemDisplay[box FILTLVL=9]: %NAME%{%NAME% 3 Minute Mapper & Rejuves (9)}%CONTINUE%
ItemDisplay[box FILTLVL=10]: %NAME%{%NAME% 3 Minute Mapper (10)}%CONTINUE%
ItemDisplay[box FILTLVL=11]: %NAME%{%NAME% No Items Out of Town (11)}%CONTINUE%

ItemDisplay[box]: %NAME%{%NAME%%CL%}%CONTINUE%
ItemDisplay[box CLVL=99]: %NAME%{%CL%%PURPLE%Grats on 99%CL%%CL%%NAME%}%CONTINUE%
ItemDisplay[box]: %NAME%{%NAME%}%MAP-58%
//-----------------------------------------------------------------------------------

//-----------------------------------------------------------------------------------
// FORCE SHOW RULES
//-----------------------------------------------------------------------------------
ItemDisplay[FILTLVL=0 (hp1 OR hp2 OR hp3 OR hp4 OR hp5 OR mp1 OR mp2 OR mp3 OR mp4 OR hp5)]: %NAME% - Filter is off{%NAME%%NL%%RED%> > > FILTER IS DISABLED < < <}// Fallback for when filter is off
ItemDisplay[FILTLVL=0]: %NAME%{%NAME%%NL%%RED%> > > FILTER IS DISABLED < < <}// Fallback for when filter is off

// QTY Alias
Alias[QTY_TAG]: %TAN%x %QTY%
// Show Quantity on Items - Quantity has to be high up in the filter for PD2 specific items
ItemDisplay[!(ARMOR OR WEAPON OR tbk OR ibk OR key OR rkey OR rid OR rtp OR aqv OR aqv2 OR aqv3 OR cqv OR cqv2 OR cqv3) QTY>1 QTY<51 !(RUNE>0)]: %NAME% %QTY_TAG%%CONTINUE%

// Lucion item in Lucion
ItemDisplay[amu STAT206>0 (MAPID=188 OR MAPID=189)]: %MAP-58%%BLACK%<%RED%!%BLACK%> %BLACK%<%RED%!%BLACK%> %BLACK%<%RED%!%BLACK%>   %RED%Amulet   %BLACK%<%RED%!%BLACK%> %BLACK%<%RED%!%BLACK%> %BLACK%<%RED%!%BLACK%>%CL%%ORANGE%Did it live?
//-----------------------------------------------------------------------------------




//------------------------------------
//----- Tier List
ItemDisplay[INF PRICE=1 DIFF<1]: %NAME%{%BLACK%~%CL%%BLUE%tinyurl.com/HiimPD2%CL%%BLACK%~%CL%%GOLD%Hiim Mapping Build Tier Lists:%CL%%BLACK%~%CL%%NAME%}%CONTINUE%

//-----------------------------------------------------------------------------------
// HIDE JUNK RULES
//-----------------------------------------------------------------------------------
ItemDisplay[(ARMOR OR WEAPON) INF !SHOP]:{%NAME%}// Hide inferior items
ItemDisplay[ear]:// Hide player ears
ItemDisplay[NMAG ID (ARMOR OR WEAPON) SOCK=1 !leg CLVL>80]:// Hide junk 10s stuff always after 80
ItemDisplay[NMAG ID (ARMOR OR WEAPON) SOCK=1 !leg CLVL>60 FILTLVL>2]:// Hide junk 10s stuff on higher Filter levels after 60
//-----------------------------------------------------------------------------------

//-----------------------------------------------------------------------------------
// Desecrated
//-----------------------------------------------------------------------------------
ItemDisplay[STAT206>0 MAG]: %BLUE%%NAME%%CONTINUE%
ItemDisplay[STAT206>0 RARE]: %YELLOW%%NAME%%CONTINUE%
ItemDisplay[STAT206>0 CRAFT]: %ORANGE%%NAME%%CONTINUE%
ItemDisplay[STAT206>0 SET]: %GREEN%%NAME%%CONTINUE%
ItemDisplay[STAT206>0 GROUND]: %BORDER-55%%MAP-58%%GOLD%Desecrated %NAME%
ItemDisplay[STAT206>0]: %NAME%

//-----------------------------------------------------------------------------------
// ONLYs FILTER ENFORCEMENT
//-----------------------------------------------------------------------------------
// Shows 
ItemDisplay[STAT206>0 FILTLVL>10 !(MAPID=1 OR MAPID=40 OR MAPID=75 OR MAPID=103 OR MAPID=109)]: %MAP-58%%NAME% %RED%[C]%GOLD%[D]// In case you drop a piece of gear on potions only show all desc slammed gear
ItemDisplay[STAT360>0 FILTLVL>10 !NMAG !(MAPID=1 OR MAPID=40 OR MAPID=75 OR MAPID=103 OR MAPID=109)]: %MAP-58%%NAME% %RED%[C]// In case you drop a piece of gear on potions only show all slammed gear
ItemDisplay[RW FILTLVL>10 !(MAPID=1 OR MAPID=40 OR MAPID=75 OR MAPID=103 OR MAPID=109)]: %MAP-58%%NAME%// In case you drop a piece of gear on potions only show all runeword gear
// Hide EVERYTHING ELSE
//ItemDisplay[FILTLVL>10 !(rvl OR rvs) !(MAPID=1 OR MAPID=40 OR MAPID=75 OR MAPID=103 OR MAPID=109) !SHOP !EQUIPPED (ARMOR OR WEAPON OR cm1 OR cm2 OR cm3 OR rin OR amu OR aqv OR cqv)]:%NOTIFY-DEAD%
ItemDisplay[FILTLVL>10 !(rvl OR rvs) !(MAPID=1 OR MAPID=40 OR MAPID=75 OR MAPID=103 OR MAPID=109) !SHOP !EQUIPPED]:%NOTIFY-DEAD%
//-----------------------------------------------------------------------------------

//-----------------------------------------------------------------------------------
// GOLD
//-----------------------------------------------------------------------------------
ItemDisplay[GOLD<100 CLVL<18]:
ItemDisplay[GOLD<1000 (CLVL>17 AND CLVL<80)]:
ItemDisplay[GOLD<5000 CLVL>79]:
//-----------------------------------------------------------------------------------
